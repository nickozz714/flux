+compose_add_dbs() {
+  local norm="$1" out="$2"
+  local site_name site site_net
+  site_name="$(json_get '.name' "$norm")"
+  site="$(safe_id "$site_name")"
+  site_net="${site}_internal"
+
+  local len; len="$(jq '.dbs | length' "$norm")"
+  [ "$len" -gt 0 ] || return 0
+
+  for i in $(seq 0 $((len-1))); do
+    local id engine db_name db_user db_pass db_root db_init db_ver
+    id="$(jq -r ".dbs[$i].id // \"db\"" "$norm")"
+    engine="$(jq -r ".dbs[$i].engine // \"mysql\"" "$norm")"
+    db_name="$(jq -r ".dbs[$i].name // empty" "$norm")"
+    db_user="$(jq -r ".dbs[$i].user // empty" "$norm")"
+    db_pass="$(jq -r ".dbs[$i].password // empty" "$norm")"
+    db_root="$(jq -r ".dbs[$i].rootPassword // empty" "$norm")"
+    db_init="$(jq -r ".dbs[$i].initSql // empty" "$norm")"
+    db_ver="$(jq -r ".dbs[$i].version // empty" "$norm")"
+
+    [ -n "$engine" ] && [ "$engine" != "null" ] || continue
+    local dbid; dbid="$(safe_id "$id")"
+    local svc="${site}-db-${dbid}"
+    local vol="db-${dbid}-data"
+
+    case "$engine" in
+      mysql|mariadb)
+        local img="mysql:8"
+        [ "$engine" = "mariadb" ] && img="mariadb:${db_ver:-11}"
+        cat >> "$out" <<YAML
+  ${svc}:
+    image: ${img}
+    container_name: ${svc}
+    networks: [${site_net}]
+    environment:
+      - MYSQL_ROOT_PASSWORD=${db_root}
+      - MYSQL_DATABASE=${db_name}
+$( [ -n "$db_user" ] && echo "      - MYSQL_USER=${db_user}" )
+$( [ -n "$db_pass" ] && echo "      - MYSQL_PASSWORD=${db_pass}" )
+    volumes:
+      - ${vol}:/var/lib/mysql
+$( [ -n "$db_init" ] && echo "      - ./${db_init}:/docker-entrypoint-initdb.d/01_init.sql:ro" )
+    healthcheck:
+      test: ["CMD", "mysqladmin", "ping", "-h", "127.0.0.1", "--password=${db_root}", "--user=root"]
+      interval: 10s
+      timeout: 5s
+      retries: 10
+    restart: unless-stopped
+
+YAML
+        ;;
+      postgres)
+        cat >> "$out" <<YAML
+  ${svc}:
+    image: postgres:${db_ver:-16}
+    container_name: ${svc}
+    networks: [${site_net}]
+    environment:
+      - POSTGRES_PASSWORD=${db_root}
+      - POSTGRES_DB=${db_name}
+$( [ -n "$db_user" ] && echo "      - POSTGRES_USER=${db_user}" )
+    volumes:
+      - ${vol}:/var/lib/postgresql/data
+$( [ -n "$db_init" ] && echo "      - ./${db_init}:/docker-entrypoint-initdb.d/01_init.sql:ro" )
+    healthcheck:
+      test: ["CMD-SHELL", "pg_isready -U ${db_user:-postgres} -d ${db_name}"]
+      interval: 10s
+      timeout: 5s
+      retries: 10
+    restart: unless-stopped
+
+YAML
+        ;;
+      *)
+        echo "WARN: Unsupported db.engine '${engine}' — skipping DB service id=${id}." ;;
+    esac
+  done
+}

