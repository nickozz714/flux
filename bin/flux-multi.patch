+# Multi-DB helpers:
+# - add --db <id> to db commands
+# - default: prefer id "main" if exists, else first dbs[0], else legacy "db"
+pick_db_id() {
+  local norm="$1" wanted="${2:-}"
+  if [ -n "$wanted" ]; then echo "$wanted"; return 0; fi
+  if jq -e '.dbs[]? | select(.id=="main")' "$norm" >/dev/null 2>&1; then echo "main"; return 0; fi
+  jq -r '.dbs[0].id // "db"' "$norm"
