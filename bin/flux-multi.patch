+
+db_engine_for() {
+  local norm="$1" dbid="${2:-}"
+  local use; use="$(pick_db_id "$norm" "$dbid")"
+  jq -r --arg id "$use" '.dbs[]? | select(.id==$id) | .engine' "$norm" | head -n1
+}
+
+db_fields_for() {
